{
  "name": "inventory-management-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typeorm": "ts-node -P tsconfig.json ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d app/lib/db.ts",
    "migration:run": "npm run typeorm -- migration:run -d app/lib/db.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d app/lib/db.ts"
  },
  "dependencies": {
    "@stackframe/stack": "^2.8.71",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pg": "^8.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
